<?xml version="1.0" encoding="UTF-8"?>
<routes xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="http://sumo.dlr.de/xsd/routes_file.xsd">
    <vType id="car" vClass="passenger" accel="2.6" decel="4.5" sigma="0.5" length="5.0" maxSpeed="13.89" carFollowModel="Krauss"/>
    <vType id="truck" vClass="truck" accel="1.2" decel="2.5" sigma="0.5" length="10.0" maxSpeed="11.11" carFollowModel="Krauss"/>
    <vType id="bus" vClass="bus" accel="1.2" decel="2.5" sigma="0.5" length="12.0" maxSpeed="11.11" carFollowModel="Krauss"/>
    <vTypeDistribution id="mixed_traffic" vTypes="car truck bus" probabilities="0.6 0.2 0.2"/>

    <!-- 
        NORMAL DISTRIBUTION APPROXIMATION:
        Traffic peaks around t=250s and tapers off at the start and end.
    -->

    <!-- West to Center -->
    <flow id="W_0" type="mixed_traffic" from="W2C" to="C2E" begin="0"   end="100" number="10" departLane="random" departSpeed="max"/>
    <flow id="W_1" type="mixed_traffic" from="W2C" to="C2E" begin="100" end="200" number="35" departLane="random" departSpeed="max"/>
    <flow id="W_2" type="mixed_traffic" from="W2C" to="C2E" begin="200" end="300" number="60" departLane="random" departSpeed="max"/>
    <flow id="W_3" type="mixed_traffic" from="W2C" to="C2E" begin="300" end="400" number="35" departLane="random" departSpeed="max"/>
    <flow id="W_4" type="mixed_traffic" from="W2C" to="C2E" begin="400" end="500" number="10" departLane="random" departSpeed="max"/>

    <!-- East to Center -->
    <flow id="E_0" type="mixed_traffic" from="E2C" to="C2W" begin="0"   end="100" number="10" departLane="random" departSpeed="max"/>
    <flow id="E_1" type="mixed_traffic" from="E2C" to="C2W" begin="100" end="200" number="35" departLane="random" departSpeed="max"/>
    <flow id="E_2" type="mixed_traffic" from="E2C" to="C2W" begin="200" end="300" number="60" departLane="random" departSpeed="max"/>
    <flow id="E_3" type="mixed_traffic" from="E2C" to="C2W" begin="300" end="400" number="35" departLane="random" departSpeed="max"/>
    <flow id="E_4" type="mixed_traffic" from="E2C" to="C2W" begin="400" end="500" number="10" departLane="random" departSpeed="max"/>

    <!-- North to Center -->
    <flow id="N_0" type="mixed_traffic" from="N2C" to="C2S" begin="0"   end="100" number="10" departLane="random" departSpeed="max"/>
    <flow id="N_1" type="mixed_traffic" from="N2C" to="C2S" begin="100" end="200" number="35" departLane="random" departSpeed="max"/>
    <flow id="N_2" type="mixed_traffic" from="N2C" to="C2S" begin="200" end="300" number="60" departLane="random" departSpeed="max"/>
    <flow id="N_3" type="mixed_traffic" from="N2C" to="C2S" begin="300" end="400" number="35" departLane="random" departSpeed="max"/>
    <flow id="N_4" type="mixed_traffic" from="N2C" to="C2S" begin="400" end="500" number="10" departLane="random" departSpeed="max"/>

    <!-- South to Center -->
    <flow id="S_0" type="mixed_traffic" from="S2C" to="C2N" begin="0"   end="100" number="10" departLane="random" departSpeed="max"/>
    <flow id="S_1" type="mixed_traffic" from="S2C" to="C2N" begin="100" end="200" number="35" departLane="random" departSpeed="max"/>
    <flow id="S_2" type="mixed_traffic" from="S2C" to="C2N" begin="200" end="300" number="60" departLane="random" departSpeed="max"/>
    <flow id="S_3" type="mixed_traffic" from="S2C" to="C2N" begin="300" end="400" number="35" departLane="random" departSpeed="max"/>
    <flow id="S_4" type="mixed_traffic" from="S2C" to="C2N" begin="400" end="500" number="10" departLane="random" departSpeed="max"/>
</routes>
