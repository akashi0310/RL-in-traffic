<?xml version="1.0" encoding="UTF-8"?>
<routes xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="http://sumo.dlr.de/xsd/routes_file.xsd">
    <!-- Define the vehicle types -->
    <vType id="car" vClass="passenger" accel="2.6" decel="4.5" sigma="0.5" length="5.0" maxSpeed="13.89" carFollowModel="Krauss"/>
    <vType id="truck" vClass="truck" accel="1.2" decel="2.5" sigma="0.5" length="10.0" maxSpeed="11.11" carFollowModel="Krauss"/>
    <vType id="bus" vClass="bus" accel="1.2" decel="2.5" sigma="0.5" length="12.0" maxSpeed="11.11" carFollowModel="Krauss"/>

    <!-- Define mixed vehicle distribution -->
    <vTypeDistribution id="mixed_traffic" vTypes="car truck bus" probabilities="0.6 0.2 0.2"/>

    <!-- 
        TRAFFIC JAM SCENARIO:
        20 vehicles per lane are spawned within the first 60 seconds.
        This creates immediate heavy congestion at the intersection J8.
    -->

    <!-- West to Center -->
    <flow id="W_straight" type="mixed_traffic" from="W2C" to="C2E" begin="0" end="60" number="20" departLane="1" departSpeed="max"/>
    <flow id="W_right"    type="mixed_traffic" from="W2C" to="C2S" begin="0" end="60" number="20" departLane="0" departSpeed="max"/>
    <flow id="W_left"     type="mixed_traffic" from="W2C" to="C2N" begin="0" end="60" number="20" departLane="2" departSpeed="max"/>

    <!-- East to Center -->
    <flow id="E_straight" type="mixed_traffic" from="E2C" to="C2W" begin="0" end="60" number="20" departLane="1" departSpeed="max"/>
    <flow id="E_right"    type="mixed_traffic" from="E2C" to="C2N" begin="0" end="60" number="20" departLane="0" departSpeed="max"/>
    <flow id="E_left"     type="mixed_traffic" from="E2C" to="C2S" begin="0" end="60" number="20" departLane="2" departSpeed="max"/>

    <!-- North to Center -->
    <flow id="N_straight" type="mixed_traffic" from="N2C" to="C2S" begin="0" end="60" number="20" departLane="1" departSpeed="max"/>
    <flow id="N_right"    type="mixed_traffic" from="N2C" to="C2W" begin="0" end="60" number="20" departLane="0" departSpeed="max"/>
    <flow id="N_left"     type="mixed_traffic" from="N2C" to="C2E" begin="0" end="60" number="20" departLane="2" departSpeed="max"/>

    <!-- South to Center -->
    <flow id="S_straight" type="mixed_traffic" from="S2C" to="C2N" begin="0" end="60" number="20" departLane="1" departSpeed="max"/>
    <flow id="S_right"    type="mixed_traffic" from="S2C" to="C2E" begin="0" end="60" number="20" departLane="0" departSpeed="max"/>
    <flow id="S_left"     type="mixed_traffic" from="S2C" to="C2W" begin="0" end="60" number="20" departLane="2" departSpeed="max"/>
</routes>
