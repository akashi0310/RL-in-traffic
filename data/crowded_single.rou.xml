    <flow id="W_r1" type="mixed_traffic" from="W2C" to="C2S" begin="100" end="200" number="4"  departLane="best" departSpeed="max"/>
    <flow id="W_r2" type="mixed_traffic" from="W2C" to="C2S" begin="200" end="300" number="4"  departLane="best" departSpeed="max"/>
    <flow id="W_r3" type="mixed_traffic" from="W2C" to="C2S" begin="300" end="400" number="4"  departLane="best" departSpeed="max"/>
