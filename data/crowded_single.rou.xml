<?xml version="1.0" encoding="UTF-8"?>
<routes xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="http://sumo.dlr.de/xsd/routes_file.xsd">
    <vType id="car" vClass="passenger" accel="2.6" decel="4.5" sigma="0.5" length="5.0" maxSpeed="13.89" carFollowModel="Krauss"/>
    <vType id="truck" vClass="truck" accel="1.2" decel="2.5" sigma="0.5" length="10.0" maxSpeed="11.11" carFollowModel="Krauss"/>
    <vType id="bus" vClass="bus" accel="1.2" decel="2.5" sigma="0.5" length="12.0" maxSpeed="11.11" carFollowModel="Krauss"/>
    <vTypeDistribution id="mixed_traffic" vTypes="car truck bus" probabilities="0.6 0.2 0.2"/>

    <!--
        CROWDED SINGLE AXIS (N-S heavy, E-W light):
        N-S: high constant volume (60/25/15 per 100s)
        E-W: low background traffic (10/4/2 per 100s)
        Randomly picks NS or EW dominance — this file is NS-heavy.
        A second variant (crowded_single_ew) is selected by the env.
    -->

    <!-- ── North (HEAVY) ─────────────────────────────────────── -->
    <flow id="N_s0" type="mixed_traffic" from="N2C" to="C2S" begin="0"   end="100" number="60" departLane="best" departSpeed="max"/>
    <flow id="N_s1" type="mixed_traffic" from="N2C" to="C2S" begin="100" end="200" number="60" departLane="best" departSpeed="max"/>
    <flow id="N_s2" type="mixed_traffic" from="N2C" to="C2S" begin="200" end="300" number="60" departLane="best" departSpeed="max"/>
    <flow id="N_s3" type="mixed_traffic" from="N2C" to="C2S" begin="300" end="400" number="60" departLane="best" departSpeed="max"/>
    <flow id="N_s4" type="mixed_traffic" from="N2C" to="C2S" begin="400" end="500" number="60" departLane="best" departSpeed="max"/>
    <flow id="N_r0" type="mixed_traffic" from="N2C" to="C2W" begin="0"   end="100" number="25" departLane="best" departSpeed="max"/>
    <flow id="N_r1" type="mixed_traffic" from="N2C" to="C2W" begin="100" end="200" number="25" departLane="best" departSpeed="max"/>
    <flow id="N_r2" type="mixed_traffic" from="N2C" to="C2W" begin="200" end="300" number="25" departLane="best" departSpeed="max"/>
    <flow id="N_r3" type="mixed_traffic" from="N2C" to="C2W" begin="300" end="400" number="25" departLane="best" departSpeed="max"/>
    <flow id="N_r4" type="mixed_traffic" from="N2C" to="C2W" begin="400" end="500" number="25" departLane="best" departSpeed="max"/>
    <flow id="N_l0" type="mixed_traffic" from="N2C" to="C2E" begin="0"   end="100" number="15" departLane="best" departSpeed="max"/>
    <flow id="N_l1" type="mixed_traffic" from="N2C" to="C2E" begin="100" end="200" number="15" departLane="best" departSpeed="max"/>
    <flow id="N_l2" type="mixed_traffic" from="N2C" to="C2E" begin="200" end="300" number="15" departLane="best" departSpeed="max"/>
    <flow id="N_l3" type="mixed_traffic" from="N2C" to="C2E" begin="300" end="400" number="15" departLane="best" departSpeed="max"/>
